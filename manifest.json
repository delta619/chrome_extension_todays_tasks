{
  "manifest_version": 3,
  "name": "Todays tasks",
  "description": "A focused to-do list tied to the website you're on. Tasks on YouTube stay on YouTube, tasks on Wikipedia stay on Wikipedia — one click to see only what matters right now.",
  "version": "1.2.3",
  "permissions": [
    "storage",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "oauth2": {
    "client_id": "191212625078-hvp8d3h4f4irfoqsrumsj36fuu1em6rj.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/drive.appdata"]
  },
  "action": {
    "default_popup": "./src/index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
