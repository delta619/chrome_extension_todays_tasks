{
  "manifest_version": 3,
  "name": "Todays tasks",
  "description": "Base Level Extension",
  "version": "1.2",
  "permissions": [
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "./src/index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
